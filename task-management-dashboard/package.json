{
  "name": "task-management-dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "start:api": "json-server --watch db.json --port 3000",
    "start:all": "concurrently \"npm run start\" \"npm run start:api\""
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "npm@10.4.0",
  "dependencies": {
    "@angular/cdk": "^22.0.0-next.1",
    "@angular/common": "^22.0.0-next.0",
    "@angular/compiler": "^22.0.0-next.0",
    "@angular/core": "^22.0.0-next.0",
    "@angular/forms": "^22.0.0-next.0",
    "@angular/material": "^22.0.0-next.1",
    "@angular/platform-browser": "^22.0.0-next.0",
    "@angular/router": "^22.0.0-next.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0-next.2",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^22.0.0-next.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.3.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
